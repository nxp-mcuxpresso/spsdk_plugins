@Library('shared-lib') _

// Abort older builds
def buildNumber = BUILD_NUMBER as int
if (buildNumber > 1) milestone(buildNumber - 1)
milestone(buildNumber)

pipeline {
    agent { label 'linux-spsdk' }
    // agent any
    options {
        timeout(time: 1, unit: 'HOURS', activity: true)   // timeout on whole pipeline job
    }
    stages {
            stage ("Checkout") {
                steps {
                    script {
                        checkoutRepo()
                        checkoutRepo("spsdk", "master", "spsdk_repo")
                    }
                }
            }
        stage ("Test") {
            steps {
                script {
                    try {
                        withVenv(
                            "uv pip install nox tomli",
                            "nox -P 3.10 3.13 --session codecheck -- --spsdk spsdk_repo -s -o reports",
                        )
                    } finally {
                        archiveArtifacts(artifacts: '*/reports*/*.txt', allowEmptyArchive: true)
                    }
                }
            }
        }    
    }
}